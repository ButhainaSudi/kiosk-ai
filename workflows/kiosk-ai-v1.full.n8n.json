        "pythonCode": "import re\nfrom datetime import datetime, timezone\n\nout = []\nfor item in items:\n    raw = item['json']['raw']\n    msg = (((raw.get('entry') or [{}])[0].get('changes') or [{}])[0].get('value', {}).get('messages') or [{}])[0]\n    rider_phone = msg.get('from', '')\n    button_id = ((msg.get('interactive') or {}).get('button_reply') or {}).get('id', '')\n\n    m = re.match(r'^ACCEPT_ORD_(.+)$', button_id)\n    if not m:\n        out.append({'json': {'ok': False, 'reason': 'invalid_button'}})\n        continue\n\n    out.append({'json': {\n        'ok': True,\n        'order_id': m.group(1),\n        'rider_phone': rider_phone,\n        'assigned_at': datetime.now(timezone.utc).isoformat()\n    }})\n\nreturn out"
