        "pythonCode": "from datetime import datetime\n\nin_data = items[0]['json']\namount = float(in_data.get('total_amount', 0))\nif amount <= 0:\n    raise Exception('Invalid total_amount from flow payload')\norder_id = 'ORD-' + datetime.utcnow().strftime('%Y%m%d%H%M%S')\n\nout = [{\n    'json': {\n        **in_data,\n        'order_id': order_id,\n        'amount': amount,\n        'currency': 'TZS',\n        'payment_status': 'PENDING',\n        'dispatch_status': 'PENDING'\n    }\n}]\nreturn out"
