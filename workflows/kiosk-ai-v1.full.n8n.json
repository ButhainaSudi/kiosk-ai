        "pythonCode": "import json\nfrom datetime import datetime\n\nout = []\nfor item in items:\n    raw = item['json']['raw']\n    msg = (((raw.get('entry') or [{}])[0].get('changes') or [{}])[0].get('value', {}).get('messages') or [{}])[0]\n    customer_phone = msg.get('from', '')\n    nfm = (msg.get('interactive') or {}).get('nfm_reply') or {}\n    response_json = nfm.get('response_json', '{}')\n    flow_data = json.loads(response_json) if isinstance(response_json, str) else (response_json or {})\n\n    out.append({'json': {\n        'customer_phone': customer_phone,\n        'buyer_name': flow_data.get('buyer_name', 'WhatsApp Customer'),\n        'buyer_email': flow_data.get('buyer_email', 'customer@example.com'),\n        'buyer_phone': flow_data.get('buyer_phone', customer_phone),\n        'delivery_address': flow_data.get('delivery_address', ''),\n        'cart_items': flow_data.get('cart_items', []),\n        'total_amount': float(flow_data.get('total_amount', 0)),\n        'submitted_at': datetime.utcnow().isoformat() + 'Z'\n    }})\nreturn out"
