# =========================
# n8n Core
# =========================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=https://your-public-domain-or-ngrok-url
GENERIC_TIMEZONE=Africa/Dar_es_Salaam
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=replace_with_32_plus_chars_random_string

# Production (docker-compose.prod.yml + nginx): use your real hostname and https
# N8N_HOST=n8n.yourdomain.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://n8n.yourdomain.com
# N8N_SECURE_COOKIE=true

# =========================
# Postgres
# =========================
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_strong_password
POSTGRES_DB=n8n

# =========================
# Kiosk AI Secrets / Config
# =========================
META_WA_TOKEN=wa_token_dummy_123
META_WA_PHONE_ID=wa_phone_id_dummy_456
CLAUDE_API_KEY=sk-ant-dummy-789
SELCOM_API_KEY=selcom_key_dummy_000
SELCOM_API_SECRET=selcom_secret_dummy_111
YANGO_API_KEY=yango_key_dummy_222

# Required IDs/URLs
SELCOM_VENDOR_ID=vendor_dummy_001
SELCOM_WEBHOOK_URL=https://your-public-domain-or-ngrok-url/webhook/selcom-callback
GSHEET_CONFIG_ID=your_google_sheet_id

# Put the Claude system prompt here as one line or escaped multiline.
# Recommended: copy from prompts/claude_system_prompt.txt and replace newlines with \n
CLAUDE_SYSTEM_PROMPT=You are Kiosk AI assistant for a Tanzanian SME on WhatsApp.
