    {
      "parameters": {
        "language": "python",
        "mode": "runOnceForAllItems",
        "pythonCode": "import os, json, hmac, hashlib\nfrom datetime import datetime, timezone\n\nout = []\nfor item in items:\n    src = item['json']\n    api_key = os.getenv('SELCOM_API_KEY', 'selcom_key_dummy_000')\n    api_secret = os.getenv('SELCOM_API_SECRET', 'selcom_secret_dummy_111')\n    vendor = os.getenv('SELCOM_VENDOR_ID', 'vendor_dummy_001')\n    webhook_url = os.getenv('SELCOM_WEBHOOK_URL', 'https://n8n.yourdomain.com/webhook/selcom-callback')\n\n    payload = {\n        'vendor': vendor,\n        'order_id': src['order_id'],\n        'buyer_email': src['buyer_email'],\n        'buyer_name': src['buyer_name'],\n        'buyer_phone': src['buyer_phone'],\n        'amount': src['amount'],\n        'currency': src['currency'],\n        'webhook_url': webhook_url,\n        'payment_methods': ['SELCOM_PAY/MASTERCARD']\n    }\n\n    ts = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\n    body = json.dumps(payload, separators=(',', ':'), sort_keys=True)\n    sig = hmac.new(api_secret.encode(), f'{ts}.{body}'.encode(), hashlib.sha256).hexdigest()\n\n    out.append({'json': {\n        **src,\n        'selcom_payload': payload,\n        'selcom_headers': {\n            'Authorization': f'Bearer {api_key}',\n            'Content-Type': 'application/json',\n            'X-Timestamp': ts,\n            'X-Signature': sig,\n            'X-Api-Key': api_key\n        }\n    }})\nreturn out"
      },
